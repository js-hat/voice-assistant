# Required
OPENAI_API_KEY=sk-...

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# Security
CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# OpenAI Realtime
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VOICE=marin
ASSISTANT_INSTRUCTIONS=You are a helpful AI assistant. Be concise.